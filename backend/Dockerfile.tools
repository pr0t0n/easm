# SAST/Secrets/Deps
RUN pip install semgrep bandit trufflehog
RUN npm install -g retire eslint jshint @ast-grep/cli tree-sitter-cli js-beautify
RUN go install github.com/zricethezav/gitleaks/v8@latest
RUN curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin

# Vuln/Exploitation
RUN apt-get update && apt-get install -y nmap masscan hydra john hashcat zaproxy sqlmap whatweb nikto wpscan sslscan dirb dnsenum
RUN go install github.com/robertdavidgraham/masscan@latest
RUN go install github.com/lgandx/Responder@latest
RUN go install github.com/byt3bl33d3r/CrackMapExec@latest
