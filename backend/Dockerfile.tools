RUN go install github.com/projectdiscovery/naabu/v2/cmd/naabu@latest

# OSINT
RUN pip install theHarvester shodan h8mail metagoofil

# Utilitários
RUN apt-get update && apt-get install -y chromium-browser curl git jq python3-pip ruby npm cargo build-essential libssl-dev libpcap-dev dnsutils unzip wget openjdk-21-jre-headless
RUN pip install playwright
RUN npm install -g playwright
RUN pip install gemini brave-browser

# Outras dependências
RUN apt-get update && apt-get install -y perl libjson-perl libxml-writer-perl

# Ajustes finais
RUN go clean -modcache
RUN npm cache clean --force
RUN pip cache purge
