APP_NAME=ScriptKidd.o
APP_ENV=development
SECRET_KEY=change_this_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

POSTGRES_DB=scriptkiddo
POSTGRES_USER=scriptkiddo
POSTGRES_PASSWORD=scriptkiddo

DATABASE_URL=postgresql+psycopg2://scriptkiddo:scriptkiddo@postgres:5432/scriptkiddo
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
LANGGRAPH_CHECKPOINTER_DSN=postgresql://scriptkiddo:scriptkiddo@postgres:5432/scriptkiddo

OLLAMA_BASE_URL=http://ollama:11434
LLM_PRIMARY_PROVIDER=ollama
LLM_PRIMARY_MODEL=llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_QWEN_MODEL=llama3.2:3b
OLLAMA_CLOUDCODE_MODEL=llama3.2:3b
LLM_EVALUATION_MODEL=llama3.2:3b

# Anthropic (opcional) — supervisor principal continua em Ollama local.
# Quando definida, habilita claude_client para tarefas auxiliares (relatórios, análises).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Observability & Evaluation (alinhamento Cyber-AutoAgent)
ENABLE_OBSERVABILITY=false
ENABLE_AUTO_EVALUATION=false
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LLM Risk Assessment (red-team para endpoints de LLM)
LLM_RISK_ENABLED=false
LLM_RISK_PROVIDER=ollama
LLM_RISK_OLLAMA_MODEL=llama3.2:3b
LLM_RISK_STRATEGY_PROFILE=balanced
LLM_RISK_STRATEGIES=prompt-injection,jailbreak,jailbreak:composite
LLM_RISK_NUM_TESTS=5
LLM_RISK_TIMEOUT_SECONDS=15

FRONTEND_ORIGIN=http://localhost:5174
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Exemplo PROD GCP: ^https://([a-z0-9-]+\.)?suaempresa\.com$
FRONTEND_ORIGIN_REGEX=

# Frontend browser -> backend API.
# Em cloud, defina com a URL publica da API, por exemplo:
# VITE_API_URL=https://api.seudominio.com
VITE_API_URL=

# Burp Pro para o container dedicado burp_rest.
BURP_LICENSE_KEY=

# Controle de execucao de ferramentas nos workers (LangGraph)
# controlled: execucao governada por autorizacao e policy
# live: execucao com adaptadores operacionais em ambiente autorizado
TOOL_EXECUTION_MODE=controlled
TOOL_ALLOWED_SCOPES=authorized_only
# Blocks "full" scans when the tool_health_snapshot shows required tools broken.
# Fail-open when no snapshot exists yet; kept fresh by the refresh_tool_health_snapshot
# celery beat task (every 20min), so this can safely default to enforcing.
ENFORCE_TOOL_HEALTH_PRECHECK=true

# Infraestrutura de pentest automatizado.
EVIDENCE_STORAGE_PATH=/evidence
BROWSER_RUNNER_URL=http://browser_runner:9222
BROWSER_RUNNER_HOST_PORT=9222
ENABLE_BROWSER_CAPTURE=true
BROWSER_CAPTURE_HAR=true
BROWSER_CAPTURE_SCREENSHOTS=true
BROWSER_MAX_DURATION_SECONDS=180
BROWSER_WORKER_CONCURRENCY=4
EVIDENCE_WORKER_CONCURRENCY=4
ENABLE_ARTIFACT_REPLAY=true
ENABLE_OOB_VALIDATION=false

# Catalogo de testes de vulnerabilidade habilitado no compose/backend.
# Valores = nomes dos arquivos em skills/vulnerability_testing/*.md sem .md.
VULNERABILITY_CATALOG_ENABLED=true
VULNERABILITY_CATALOG_DIR=/app/skills/vulnerability_testing
VULNERABILITY_CATALOG_SKILLS=account_takeover,api_security,auth_bypass,bola_bfla,business_logic,clickjacking,command_injection,component_memory_corruption,cors_misconfiguration,crypto_storage,csrf,deserialization,graphql,host_header_injection,http_request_smuggling,idor_object_authorization,information_disclosure,jwt_oauth,open_redirect,path_traversal,race_condition,resource_consumption,sqli,sqli_testing,ssrf,ssti,stored_xss_testing,subdomain_takeover,web_cache,xss,xxe

# Variaveis lidas pelo container Kali para perfis que exigem autorizacao explicita.
# Deixe vazio para os perfis Hydra/credenciais serem marcados como skipped.
SHODAN_API_KEY=
SCAN_AUTH_USERNAME=
SCAN_AUTH_PASSWORD=
SCAN_AUTH_USERLIST=
SCAN_AUTH_PASSLIST=
SCAN_AUTH_PROTOCOL=
SCAN_FUZZ_PARAM=
SCAN_FUZZ_POST_DATA=
SCAN_FUZZ_CONTENT_TYPE=application/x-www-form-urlencoded

# Pentest Automation Lab (profile: pentest-lab)
# Start: docker compose --profile dev --profile pentest-lab up -d
LAB_JUICE_SHOP_HOST_PORT=3001
LAB_DVWA_HOST_PORT=8081
LAB_IDOR_API_HOST_PORT=8082
LAB_JUICE_SHOP_TARGET=http://juice_shop:3000
LAB_DVWA_TARGET=http://dvwa:80
LAB_IDOR_API_TARGET=http://idor_api:8080
