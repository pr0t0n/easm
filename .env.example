APP_NAME=Pentest.io
APP_ENV=development
SECRET_KEY=change_this_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

DATABASE_URL=postgresql+psycopg2://easm:easm@postgres:5432/easm
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
LANGGRAPH_CHECKPOINTER_DSN=postgresql://easm:easm@postgres:5432/easm

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_QWEN_MODEL=qwen2.5:7b
OLLAMA_CLOUDCODE_MODEL=llama3.1:8b

# LLM Risk Assessment (red-team para endpoints de LLM)
LLM_RISK_ENABLED=false
LLM_RISK_PROVIDER=ollama
LLM_RISK_OLLAMA_MODEL=qwen2.5:7b
LLM_RISK_STRATEGY_PROFILE=balanced
LLM_RISK_STRATEGIES=prompt-injection,jailbreak,jailbreak:composite
LLM_RISK_NUM_TESTS=5
LLM_RISK_TIMEOUT_SECONDS=15

FRONTEND_ORIGIN=http://localhost:5174
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Exemplo PROD GCP: ^https://([a-z0-9-]+\.)?suaempresa\.com$
FRONTEND_ORIGIN_REGEX=

# Frontend browser -> backend API.
# Em cloud, defina com a URL publica da API, por exemplo:
# VITE_API_URL=https://api.seudominio.com
VITE_API_URL=

# Burp Pro para o container dedicado burp_rest.
BURP_LICENSE_KEY=

# Controle de execucao de ferramentas nos workers (LangGraph)
# controlled: execucao governada por autorizacao e policy
# live: execucao com adaptadores operacionais em ambiente autorizado
TOOL_EXECUTION_MODE=controlled
TOOL_ALLOWED_SCOPES=authorized_only

# Modo de execução das ferramentas dentro do LangGraph
# local: fallback síncrono (necessário quando grafo roda dentro de Celery)
# distributed: despacho via Celery (trava se chamado dentro de tarefa Celery)
EASM_TOOL_EXECUTION_MODE=local
