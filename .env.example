APP_NAME=VALID ASM - vASM
APP_ENV=development
SECRET_KEY=change_this_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@vasm.local
ADMIN_PASSWORD=admin123

DATABASE_URL=postgresql+psycopg2://easm:easm@postgres:5432/easm
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
LANGGRAPH_CHECKPOINTER_DSN=postgresql://easm:easm@postgres:5432/easm

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

FRONTEND_ORIGIN=http://localhost:5173

# Controle de execucao de ferramentas nos workers (LangGraph)
# stub: nao executa binarios, apenas planeja a acao
# live: executa adaptadores reais em ambiente autorizado
TOOL_EXECUTION_MODE=stub
TOOL_ALLOWED_SCOPES=authorized_only
